{
  "name": "free-browser-agent",
  "version": "0.1.0",
  "description": "Open-source MV3 Chrome extension for agentic browser control powered by free-tier LLM aggregation. Inspired by freellmapi.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "node build.mjs",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test test/e2e",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "openai": "^4.73.0",
    "pdfjs-dist": "^5.7.284",
    "preact": "^10.25.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "@types/chrome": "^0.0.287",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.0",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "playwright": "^1.49.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
